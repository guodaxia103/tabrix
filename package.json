{
  "name": "tabrix-monorepo",
  "version": "2.0.0",
  "private": true,
  "author": "guodaxia103",
  "type": "module",
  "scripts": {
    "build:shared": "pnpm --filter chrome-mcp-shared build",
    "build:native": "pnpm --filter tabrix build",
    "build:extension": "pnpm --filter chrome-mcp-server build",
    "build:wasm": "pnpm --filter @chrome-mcp/wasm-simd build && pnpm run copy:wasm",
    "build": "pnpm run build:shared && pnpm --parallel --filter chrome-mcp-server --filter tabrix run build:direct",
    "copy:wasm": "node ./scripts/copy-wasm.mjs",
    "dev:shared": "pnpm --filter chrome-mcp-shared dev",
    "dev:native": "pnpm --filter tabrix dev",
    "dev:extension": "pnpm --filter chrome-mcp-server dev",
    "dev": "pnpm --filter chrome-mcp-shared build && pnpm -r --parallel dev",
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm -r --if-present lint:fix",
    "format": "pnpm -r format",
    "clean:dist": "node ./scripts/clean-workspace.mjs dist",
    "clean:modules": "node ./scripts/clean-workspace.mjs modules",
    "clean": "pnpm run clean:dist && pnpm run clean:modules",
    "typecheck": "pnpm -r --if-present typecheck",
    "test:core": "pnpm -C app/native-server test && pnpm -C app/chrome-extension test",
    "test:wasm": "pnpm -C packages/wasm-simd test",
    "deps:outdated": "pnpm -r outdated",
    "audit": "pnpm audit --prod --audit-level high",
    "i18n:check": "node ./scripts/check-i18n.mjs",
    "ci:check": "pnpm run i18n:check && pnpm run typecheck && pnpm run test:core && pnpm run audit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.25.1",
    "@rolldown/binding-win32-x64-msvc": "1.0.0-rc.12",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.8.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.1",
    "vue-eslint-parser": "^10.1.3"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.12",
      "@hono/node-server": "1.19.13"
    }
  }
}
