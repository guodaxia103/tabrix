{
  "name": "@tabrix/tabrix",
  "version": "2.0.7",
  "description": "Tabrix Native-Messaging host (Node)",
  "main": "dist/index.js",
  "bin": {
    "tabrix": "./dist/cli.js",
    "tabrix-stdio": "./dist/mcp/mcp-server-stdio.js"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts,js,json --ignore dist/ --exec \"npm run build && npm run register:dev\"",
    "prebuild": "pnpm --filter @tabrix/shared build",
    "build": "pnpm run build:direct",
    "build:direct": "ts-node src/scripts/build.ts",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "test:coverage": "jest --collectCoverage",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,ts,json}\"",
    "register:dev": "node dist/scripts/register-dev.js",
    "postinstall": "node -e \"const fs=require('fs');const path=require('path');const file=path.join(process.cwd(),'dist','scripts','postinstall.js');if(fs.existsSync(file)){require(file);}else{console.log('[tabrix] Skip native postinstall in source checkout (dist/scripts/postinstall.js not found).');}\""
  },
  "files": [
    "dist",
    "!dist/node_path.txt"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "preferGlobal": true,
  "keywords": [
    "mcp",
    "chrome",
    "browser"
  ],
  "author": "guodaxia103",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guodaxia103/tabrix.git"
  },
  "bugs": {
    "url": "https://github.com/guodaxia103/tabrix/issues"
  },
  "homepage": "https://github.com/guodaxia103/tabrix#readme",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.69",
    "@fastify/cors": "^11.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tabrix/shared": "^2.0.7",
    "@types/node-fetch": "2",
    "better-sqlite3": "^11.6.0",
    "chalk": "^5.4.1",
    "chrome-devtools-frontend": "^1.0.1611825",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.2",
    "is-admin": "^4.0.0",
    "node-fetch": "2",
    "pino": "^10.3.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/chrome": "^0.0.318",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/parser": "^8.58.1",
    "cross-env": "^7.0.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.1",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.0.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
